{
  "name": "event-management-backend",
  "version": "1.0.0",
  "description": "Event Management System - Backend API",
  "main": "dist/server.js",

  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "npm run prisma:generate && npx tsc",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "start": "node dist/server.js",

    "db:generate": "prisma generate --schema src/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "db:push": "prisma db push --schema src/prisma/schema.prisma",
    "db:seed": "ts-node src/prisma/seed.ts"
  },

  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },

  "dependencies": {
    "@prisma/client": "^5.7.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "dotenv": "^16.3.1"
  },

  "devDependencies": {
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "prisma": "^5.7.0",
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17"
  }
}